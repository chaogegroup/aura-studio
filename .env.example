# ==============================================
# AURA Studio 环境配置
# ==============================================
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ==============================================

# 又拍云 S3 配置（用于图片上传）
UPYUN_AK=your_upyun_access_key
UPYUN_SK=your_upyun_secret_key
UPYUN_BUCKET=your_bucket_name
UPYUN_DOMAIN=your_domain.test.upcdn.net
UPYUN_ENDPOINT=https://s3.api.upyun.com

# 后端服务
AURA_HOST=127.0.0.1
AURA_PORT=18922
